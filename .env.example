# Optional Valve fallbacks used when OpenDota is missing replay metadata or timing out.
# Streamlit Cloud: put these in app secrets instead of committing a real .env file.

# Less reliable today (Valve Web API GetMatchDetails often returns empty/500),
# but harmless to keep if you already have one.
STEAM_API_KEY=

# Recommended robust fallback: Dota 2 GC bot credentials.
# These let the app fetch finished match details directly from Valve's GC,
# then build the replay URL from cluster + replay_salt.
BOT_STEAM_USERNAME=
BOT_STEAM_PASSWORD=
